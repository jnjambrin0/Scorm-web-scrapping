# SCORM → Notion local app — required configuration.
#
# Copy this file to `.env` and fill in the two values below. Everything else
# (the SCORM URL, output paths, Notion parent page title) is entered in the
# web form each time you run an export — no other env vars are needed.

# Notion integration token. Required for `notion-dry-run` and `notion-publish`.
# Create one at https://www.notion.so/profile/integrations and grant it access
# to the parent page you want to publish into. The token starts with
# `secret_` or `ntn_`.
NOTION_API_KEY=

# Base URL of your institution's Blackboard. Required for the `login` flow and
# the session check. Use the page you land on when you're already
# authenticated — typically the Ultra stream root. Examples:
#   https://<your-institution>.blackboard.com/ultra/stream
#   https://blackboard.<your-university>.edu/ultra/stream
BLACKBOARD_BASE_URL=
